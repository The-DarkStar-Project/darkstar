#* Distributed scanner workers
# Orchestrator URL as seen from scanner containers. For docker compose local workers:
# DARKSTAR_ORCHESTRATOR_URL='http://darkstar-web:8080'
DARKSTAR_ORCHESTRATOR_URL=''
# Create with: python3 -m darkstar.scanner_attach create --name local-scanner --url http://darkstar-web:8080
DARKSTAR_SCANNER_TOKEN=''
DARKSTAR_SCANNER_NAME='local-scanner'
DARKSTAR_WORKER_MAX_PARALLEL='1'
